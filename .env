#server
SPRING_APPLICATION_NAME=hr_management
SERVER_PORT=8081
SERVER_SERVLET_CONTEXT_PATH=/hr-management
#database
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/hr_management
SPRING_DATASOURCE_USERNAME=hr_user
SPRING_DATASOURCE_PASSWORD=123456
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_SHOW_SQL=false
# actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
# jwt
JWT_SECRET=8a7c9e3b1d5f6a9c8e7d4c2b1a3f5e6d8c7b9a1f2e3d4c5b6a7c8d9e1f2a3b4
# logging
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=ERROR
LOGGING_FILE_NAME=logs/hr_management.log